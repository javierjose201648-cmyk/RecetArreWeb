@using RecetArreWeb.DTOs

<li class="media mb-3">
    <img src="/images/default-avatar.png" class="me-3 rounded" width="48" height="48" />
    <div class="media-body">
        <div class="d-flex justify-content-between">
            <div>
                <strong>@Comentario.Usuario?.DisplayName ?? Comentario.UsuarioId</strong>
                <small class="text-muted ms-2">@Comentario.CreadoUtc.ToLocalTime().ToString("g")</small>
            </div>
            <div>
                @if (OnEdit.HasDelegate)
                {
                    <button class="btn btn-sm btn-link" @onclick="() => OnEdit.InvokeAsync(Comentario.Id)">Editar</button>
                }
                @if (OnDelete.HasDelegate)
                {
                    <button class="btn btn-sm btn-link text-danger" @onclick="() => OnDelete.InvokeAsync(Comentario.Id)">Eliminar</button>
                }
            </div>
        </div>

        <div class="mt-2">@Comentario.Contenido</div>

        @if (Comentario.RepliesCount > 0 && Comentario.Replies?.Any() == true)
        {
            <ul class="list-unstyled ms-4 mt-2">
                @foreach (var r in Comentario.Replies)
                {
                    <ComentarioItem Comentario="r" OnReply="OnReply" OnEdit="OnEdit" OnDelete="OnDelete" />
                }
            </ul>
        }
    </div>
</li>

@code {
    [Parameter]
    public ComentarioDto Comentario { get; set; } = default!;

    [Parameter]
    public EventCallback<int> OnReply { get; set; }

    [Parameter]
    public EventCallback<int> OnEdit { get; set; }

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }
}
